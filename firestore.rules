
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL TERMINAL AUTHORIZATION - DEPLOYED: 2026-03-16 10:15:00 UTC
    // Explicitly authorizing all operations for the library visitor management system.
    
    match /patrons/{patronId} {
      allow read, write: if true;
    }
    
    match /visits/{visitId} {
      allow read, write: if true;
    }
    
    match /system_config/{configId} {
      allow read, write: if true;
    }

    // Universal fallback for future-proofing
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
