
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // For prototype simplicity, we'll allow all signed-in users to access dashboard data
    // In a real app, you'd use a more robust isAdmin() check
    function isStaff() {
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /admin_accounts/{adminId} {
      allow get: if isOwner(adminId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId);
      allow delete: if isStaff();
    }

    match /patrons/{patronId} {
      allow get: if isOwner(patronId) || isStaff();
      allow list: if isStaff();
      allow create: if true; // Allow kiosk registration
      allow update: if isOwner(patronId) || isStaff();
      allow delete: if isStaff();
    }

    match /visit_purposes/{purposeId} {
      allow get, list: if true;
      allow create, update, delete: if isStaff();
    }

    match /visits/{visitId} {
      allow get, list: if isStaff();
      allow create: if true; // Allow kiosk log entries
      allow update, delete: if isStaff();
    }
  }
}
