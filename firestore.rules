
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    match /patrons/{patronId} {
      // Kiosk and Admin need broad read access for identity verification
      allow read, create: if true; 
      allow update, delete: if isSignedIn();
    }

    match /visits/{visitId} {
      // Kiosk needs to log entries; Admin needs to monitor live occupancy
      allow read, create: if true; 
      allow update, delete: if isSignedIn();
    }

    match /system_config/{configId} {
      // System branding and purposes are public
      allow read: if true; 
      allow write: if isSignedIn();
    }

    // Catch-all for any other administrative paths
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
