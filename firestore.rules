
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    // Patrons: Broad read for kiosk identity checks; staff can manage
    match /patrons/{patronId} {
      allow read, create: if true;
      allow update, delete: if isSignedIn();
    }

    // Visits: Broad read for admin dashboard and kiosk logging
    match /visits/{visitId} {
      allow read, create: if true;
      allow update, delete: if isSignedIn();
    }

    // System Config: Branding and purposes are public; staff can write
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Catch-all for any other administrative paths - ensure staff can always access
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
