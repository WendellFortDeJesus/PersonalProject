
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL TERMINAL AUTHORIZATION - DEPLOYED: 2026-03-16 12:00:00 UTC
    // Broad recursive wildcard to ensure all institutional modules have full sync capability.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
