rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL SECURITY PROTOCOL - DEPLOYMENT TIMESTAMP: 2026-03-16 04:15:00 UTC
    // Universal access granted for development phase to resolve identity hub synchronization issues.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}