rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REINFORCED INSTITUTIONAL AUTHORIZATION - DEPLOYMENT TIMESTAMP: 2026-02-21 18:05:00 UTC
    // Universal access for terminal identity hub and management portal to ensure 100% sync reliability.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}