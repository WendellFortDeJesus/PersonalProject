
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Institutional Collections ---

    // Patrons: Broad read for kiosk lookup; restricted write for admin management
    match /patrons/{patronId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Visits: Log of all entries; broad read for live occupancy metrics
    match /visits/{visitId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // System Config: Global settings for kiosk and terminal
    match /system_config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Global Catch-all ---
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
