rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL SECURITY PROTOCOL - REINFORCED DEPLOYMENT: 2026-03-16 05:45:00 UTC
    // Universal authorization for institutional terminal nodes to resolve recursive listing and sync issues.
    
    // Fallback for all documents
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit authorization for high-density collections
    match /patrons/{document=**} {
      allow read, write: if true;
    }
    
    match /visits/{document=**} {
      allow read, write: if true;
    }
    
    match /system_config/{document=**} {
      allow read, write: if true;
    }
  }
}