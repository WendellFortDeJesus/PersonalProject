
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Collection Rules ---

    // Patrons: Required for kiosk registration and admin management
    match /patrons/{patronId} {
      allow get, list, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Visits: Log of all check-in attempts; broad read for live occupancy and analytics
    match /visits/{visitId} {
      allow get, list, create: if true;
      allow update, delete: if request.auth != null;
    }

    // System Config: Global settings for the terminal and dashboard
    match /system_config/{configId} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }

    // Catch-all: Ensure authenticated staff can access any other administrative paths
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
