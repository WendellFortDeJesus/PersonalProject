
{
  "entities": {
    "Patron": {
      "title": "Patron",
      "type": "object",
      "description": "Represents a library patron (student, staff, or faculty).",
      "properties": {
        "id": { "type": "string" },
        "schoolId": { "type": "string", "description": "RFID or School ID" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Student", "Faculty", "Staff", "Visitor"] },
        "departments": { "type": "array", "items": { "type": "string" } },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "isBlocked": { "type": "boolean" },
        "blockReason": { "type": "string" },
        "isArchived": { "type": "boolean", "default": false },
        "archiveReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "photoUrl": { "type": "string" }
      },
      "required": ["id", "schoolId", "name", "isBlocked"]
    },
    "Visit": {
      "title": "Visit",
      "type": "object",
      "description": "A check-in event logged at the kiosk.",
      "properties": {
        "id": { "type": "string" },
        "patronId": { "type": "string" },
        "schoolId": { "type": "string" },
        "patronName": { "type": "string" },
        "patronDepartments": { "type": "array", "items": { "type": "string" } },
        "patronAge": { "type": "number" },
        "patronGender": { "type": "string" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["granted", "blocked"] },
        "authMethod": { "type": "string", "enum": ["RF-ID Login", "SSO Login"] },
        "isArchived": { "type": "boolean", "default": false }
      },
      "required": ["id", "patronId", "timestamp", "status", "authMethod"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "type": "object",
      "description": "Global settings for departments, purposes, and limits.",
      "properties": {
        "departments": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "code": { "type": "string" },
              "isActive": { "type": "boolean" },
              "color": { "type": "string" }
            }
          }
        },
        "purposes": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "icon": { "type": "string" }
            }
          } 
        },
        "capacityLimit": { "type": "number", "default": 200 },
        "allowEmailLogin": { "type": "boolean", "default": true },
        "allowRfidScan": { "type": "boolean", "default": true },
        "requireDeleteReason": { "type": "boolean", "default": true },
        "hardDelete": { "type": "boolean", "default": false },
        "enforcedDomain": { "type": "string", "default": "neu.edu.ph" },
        "autoClearLogs": { "type": "boolean", "default": true }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/patrons/{patronId}": {
      "schema": "#/entities/Patron",
      "description": "Library visitor profiles."
    },
    "/visits/{visitId}": {
      "schema": "#/entities/Visit",
      "description": "Log of all check-in attempts."
    },
    "/system_config/{configId}": {
      "schema": "#/entities/SystemConfig",
      "description": "Global terminal and report settings."
    }
  }
}
