rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL ACCESS OVERRIDE: 2026-02-21 17:10:00 UTC
    // Explicitly authorizing all operations for terminal collections to resolve listing errors.
    
    match /patrons/{document=**} {
      allow read, write: if true;
    }
    
    match /visits/{document=**} {
      allow read, write: if true;
    }
    
    match /system_config/{document=**} {
      allow read, write: if true;
    }

    // Broad fallback for secondary terminal paths
    match /{document=**} {
      allow read, write: if true;
    }
  }
}