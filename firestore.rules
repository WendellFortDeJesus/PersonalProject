
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY OVERRIDE: 2026-02-21 16:10:00 UTC
    // Explicitly authorizing institutional collections for the terminal identity hub.
    
    match /patrons/{patronId} {
      allow read, write: if true;
    }
    
    match /visits/{visitId} {
      allow read, write: if true;
    }
    
    match /system_config/{configId} {
      allow read, write: if true;
    }

    // Broad fallback for nested terminal paths
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
