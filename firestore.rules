rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL SECURITY PROTOCOL - DEPLOYMENT TIMESTAMP: 2026-02-21 18:25:00 UTC
    
    // Core Identity Hub Authorization
    // We explicitly allow 'list' to support high-density management tables.
    // Baseline security requires a valid institutional session (SSO or RF-ID).
    
    match /patrons/{document=**} {
      allow read, list, create: if request.auth != null;
      // Update/Delete restricted to authenticated staff
      allow update, delete: if request.auth != null;
    }
    
    match /visits/{document=**} {
      allow read, list, create, update, delete: if request.auth != null;
    }
    
    match /system_config/{document=**} {
      allow read, list, write: if request.auth != null;
    }

    // Global Fallback for Terminal Synchronization
    match /{document=**} {
      allow read, list, write: if request.auth != null;
    }
  }
}