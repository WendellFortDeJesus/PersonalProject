
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL TERMINAL AUTHORIZATION - DEPLOYED: 2026-03-16 09:30:00 UTC
    // Explicitly authorizing all operations for library visitor management system.
    
    match /patrons/{document=**} {
      allow read, write: if true;
    }
    
    match /visits/{document=**} {
      allow read, write: if true;
    }
    
    match /system_config/{document=**} {
      allow read, write: if true;
    }

    // Universal fallback for future-proofing
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
