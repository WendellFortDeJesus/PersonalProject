
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // UNIVERSAL ACCESS PROTOCOL - REINFORCED DEPLOYMENT: 2026-03-16 08:30:00 UTC
    // Explicitly authorizing collection-level operations to resolve 'list' permission errors.
    
    match /patrons {
      allow read, write: if true;
    }
    match /patrons/{document=**} {
      allow read, write: if true;
    }
    
    match /visits {
      allow read, write: if true;
    }
    match /visits/{document=**} {
      allow read, write: if true;
    }
    
    match /system_config {
      allow read, write: if true;
    }
    match /system_config/{document=**} {
      allow read, write: if true;
    }

    // Fallback for all other documents
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
